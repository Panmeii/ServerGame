# Server Configuration
PORT=3001
NODE_ENV=production

# CORS Allowed Origins (comma separated)
# Untuk production, ganti dengan domain Vercel Anda
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app,https://tiktok-game.vercel.app

# Rate Limiting
MAX_CONNECTIONS_PER_IP=10
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# TikTok Settings
TIKTOK_CONNECTION_TIMEOUT=30000
TIKTOK_RECONNECT_ATTEMPTS=3
TIKTOK_RECONNECT_DELAY=5000
